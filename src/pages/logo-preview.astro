---
// Internal logo preview page. Will be removed after a candidate is chosen.
// noindex via meta tag below.
const variants = [
  { id: 'A1', dir: 'A', name: '</>  + H bracket-glyph', concept: 'Angle brackets enclosing an H — pure code-editor energy.' },
  { id: 'A2', dir: 'A', name: '{ohos} braces with center dot', concept: 'Curly-brace scope wrapping a node — “ohos as a code block”.' },
  { id: 'A3', dir: 'A', name: 'Terminal "/." in rounded window', concept: 'Slash-dot inside a chip silhouette — IDE/terminal vibe.' },

  { id: 'B1', dir: 'B', name: 'Concentric harmony rings', concept: 'Three rings fading inward — broadcast/harmony, no petals.' },
  { id: 'B2', dir: 'B', name: 'Möbius / infinity knot', concept: 'Looped path crossing itself — continuity & interconnection.' },
  { id: 'B3', dir: 'B', name: 'Hex network shell', concept: 'Outer hexagon with solid inner hex — distributed mesh, technical.' },

  { id: 'C1', dir: 'C', name: 'Solid square + “o” glyph', concept: 'Friendly app-tile with embedded letter “o”, pairs with wordmark.' },
  { id: 'C2', dir: 'C', name: 'Ring + dot (target)', concept: 'Outline circle with center dot — focus / device target.' },

  { id: 'D1', dir: 'D', name: 'Cross node graph', concept: '4 satellite nodes linked to a central hub — cross-device fan-out.' },
  { id: 'D2', dir: 'D', name: 'Pixel quincunx', concept: '5 rounded pixels in a die-5 layout — playful pixel-grid identity.' },
  { id: 'D3', dir: 'D', name: 'Stacked device cards', concept: 'Three offset rounded screens — phone/tablet/wearable stack.' },
];

const schemes = [
  { name: 'gradient', label: 'Blue→Green gradient' },
  { name: 'mono-light', label: 'Mono (white)' },
  { name: 'mono-dark', label: 'Mono (black)' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Logo Preview — ohosdev</title>
    <style>
      :root {
        color-scheme: dark;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif;
      }
      body { margin: 0; background: #0b0d10; color: #e6e8eb; }
      .wrap { max-width: 1200px; margin: 0 auto; padding: 32px 24px 80px; }
      .banner {
        background: linear-gradient(135deg, #0066FF22, #00CC9922);
        border: 1px solid #0066FF44; border-radius: 12px;
        padding: 16px 20px; margin-bottom: 32px;
      }
      .banner h1 { margin: 0 0 6px; font-size: 20px; }
      .banner p { margin: 0; opacity: .8; font-size: 14px; }
      h2.dir { margin: 48px 0 16px; font-size: 16px; opacity: .7;
        letter-spacing: .12em; text-transform: uppercase; }
      .card {
        border: 1px solid #2a2f36; border-radius: 14px;
        padding: 18px; margin-bottom: 18px; background: #11141a;
      }
      .card h3 { margin: 0 0 4px; font-size: 16px; }
      .card .desc { margin: 0 0 14px; font-size: 13px; opacity: .65; }
      .row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
      .pane { border-radius: 10px; padding: 14px; }
      .pane.dark  { background: #0b0d10; border: 1px solid #2a2f36; }
      .pane.light { background: #f6f7f8; border: 1px solid #d8dadf; color: #111; }
      .pane h4 { margin: 0 0 10px; font-size: 11px; letter-spacing: .08em;
        text-transform: uppercase; opacity: .55; }
      .sizes { display: flex; align-items: flex-end; gap: 18px; flex-wrap: wrap; }
      .sizes .slot { display: flex; flex-direction: column; align-items: center; gap: 6px; }
      .sizes .slot span { font-size: 10px; opacity: .55; }
      .marks { display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
      .scheme-tag {
        display: inline-block; padding: 2px 8px; border-radius: 999px;
        font-size: 11px; background: #1d222a; margin-right: 6px;
        border: 1px solid #2a2f36;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="banner">
        <h1>Logo Preview — Internal use only</h1>
        <p>选定后此页将删除。下面是 4 个方向 × 多个变体的 ohosdev logo 候选；每个变体提供蓝绿渐变 / 白 / 黑 三色，并在暗/亮背景下对比显示 favicon (32) / header (64) / showcase (128) 三档尺寸。</p>
      </div>

      {['A','B','C','D'].map((dir) => (
        <>
          <h2 class="dir">Direction {dir}</h2>
          {variants.filter((v) => v.dir === dir).map((v) => (
            <div class="card">
              <h3>{v.id} — {v.name}</h3>
              <p class="desc">{v.concept}</p>

              {schemes.map((s) => {
                const showOnDark = s.name !== 'mono-dark';
                const showOnLight = s.name !== 'mono-light';
                const iconSrc = `/logos/candidates/${v.id}-${s.name}-icon.svg`;
                const markSrc = `/logos/candidates/${v.id}-${s.name}-mark.svg`;
                return (
                  <div style="margin-top:14px">
                    <span class="scheme-tag">{s.label}</span>
                    <div class="row">
                      {showOnDark && (
                        <div class="pane dark">
                          <h4>On dark</h4>
                          <div class="sizes">
                            <div class="slot"><img src={iconSrc} width="32" height="32" alt="" /><span>32</span></div>
                            <div class="slot"><img src={iconSrc} width="64" height="64" alt="" /><span>64</span></div>
                            <div class="slot"><img src={iconSrc} width="128" height="128" alt="" /><span>128</span></div>
                          </div>
                          <div class="marks">
                            <img src={markSrc} height="32" alt="" />
                            <img src={markSrc} height="48" alt="" />
                          </div>
                        </div>
                      )}
                      {showOnLight && (
                        <div class="pane light">
                          <h4>On light</h4>
                          <div class="sizes">
                            <div class="slot"><img src={iconSrc} width="32" height="32" alt="" /><span>32</span></div>
                            <div class="slot"><img src={iconSrc} width="64" height="64" alt="" /><span>64</span></div>
                            <div class="slot"><img src={iconSrc} width="128" height="128" alt="" /><span>128</span></div>
                          </div>
                          <div class="marks">
                            <img src={markSrc} height="32" alt="" />
                            <img src={markSrc} height="48" alt="" />
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          ))}
        </>
      ))}
    </div>
  </body>
</html>
